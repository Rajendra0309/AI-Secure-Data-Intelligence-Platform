# Backend Configuration

# Server port
# Default: 4000
PORT=4000

# AI service endpoint
# Default: http://localhost:8000 (local development)
# Docker: http://ai-service:8000
# Production: Use your deployed AI service URL
AI_SERVICE_URL=http://localhost:8000

# Environment mode
# Values: development | production
NODE_ENV=development

# MongoDB connection string (optional)
# If not set, MongoDB persistence will be gracefully skipped
# Local: mongodb://localhost:27017/asdip
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/asdip?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/asdip
