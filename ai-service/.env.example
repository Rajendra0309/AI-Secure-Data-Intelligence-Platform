# AI Service Configuration - LLM Providers

# ===== PRIMARY PROVIDER (Recommended: Groq Free Tier) =====
# Get free API key at: https://console.groq.com

# Primary LLM API Key
# Leave empty to use rule-based insights only
LLM_API_KEY=

# Primary LLM model identifier
# Groq free tier: llama-3.1-8b-instant, mixtral-8x7b-32768
LLM_MODEL=llama-3.1-8b-instant

# Primary LLM API base URL
# Groq: https://api.groq.com/openai/v1
# OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://api.groq.com/openai/v1

# Primary provider name (for logging and response attribution)
LLM_PROVIDER_NAME=groq

# ===== FALLBACK PROVIDER (Optional: OpenRouter) =====
# Get free API key at: https://openrouter.ai
# Fallback is used if primary provider fails

# Fallback LLM API Key
# Leave empty to skip fallback provider
LLM_FALLBACK_API_KEY=

# Fallback LLM model identifier
# OpenRouter free models: meta-llama/llama-3.1-8b-instruct:free, openchat/openchat-3.5:free
LLM_FALLBACK_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Fallback LLM API base URL
# OpenRouter: https://openrouter.ai/api/v1
LLM_FALLBACK_BASE_URL=https://openrouter.ai/api/v1

# Fallback provider name (for logging and response attribution)
LLM_FALLBACK_PROVIDER_NAME=openrouter

# ===== SYSTEM =====
# If both LLM_API_KEY and LLM_FALLBACK_API_KEY are empty,
# the system automatically uses rule-based insights (deterministic, no API calls)
